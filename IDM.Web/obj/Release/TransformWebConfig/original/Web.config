    <add name="DBConnection" connectionString="Server=PBT-DD-SQLMFG01.AD.SHARED;Database=IDM;Trusted_Connection=True;" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="MQConnectionFile" value="C:\\MQConfig\\pdb.ini" />
    <add key="MQTransaction" value="MATERIALINFOIDM" />
    <add key="MQTransactionTrial" value="PARMTRIALIDM" />
    <add key="MQVersion" value="1" />
    <add key="MQExcludeColumn" value="ID, UPDATEDBY, UPDATEDTS, ACTIVEFLAG, STORETS, LOWERSPECSLIMIT, UPPERSPECSLIMIT, LOWERCONTROLLIMIT, UPPERCONTROLLIMIT, SPECSJUDGEMENT, CONTROLJUDGEMENT, EDCSPCFLAG" />
    <add key="MQAdjustColumn" value="AREA, SUPPLIER, MANUFACTURER, UOM, SITE" />
