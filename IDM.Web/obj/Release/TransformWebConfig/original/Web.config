    <add key="SMTPHost" value="smtp.wdc.com" />
    <add key="SMTPPort" value="25" />
    <add key="EmailSender" value="MSL.Web.MngtSystem.UAT.DoNotReply@wdc.com" />
    <add key="DefaultEmailRecipients" value="christian.dale.caguimbal@wdc.com" />
    <add key="Website" value="http://pbt-md-app03/MSL_UAT" />
    <add key="BdpUploadCommonDirectory" value="\\pbt-op-onefs02.wdc.com\MSL\SEM3\BDP_Upload\" />
    <add key="BdpUploadCommonURL" value="https://hdd-bdp-imgprxy.edge.wdc.com/2PNG/mho%2Fpho%2Fimages%2Fmnt%2FPHO_MSL%2FBDP_Upload%2F" />
  </appSettings>
  <system.web>
    <sessionState mode="InProc" timeout="2880" cookieless="UseCookies" />
    <authentication mode="Forms">
      <forms loginUrl="~/Login/Login" timeout="2880" protection="All" slidingExpiration="true" cookieless="UseCookies" name=".IDMAUTH" />
    </authentication>
    <authorization>
      <deny users="?" /><!-- "?" means unauthenticated users -->
      <allow users="*" />
    </authorization>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
  </system.web>
