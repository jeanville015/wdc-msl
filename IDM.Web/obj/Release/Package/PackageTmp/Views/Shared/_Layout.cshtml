
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MSL MS</title>
    
    <!-- FontAwesome CDN Fallback for IIS Deployment -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    @Styles.Render("~/Content/adminlte")
    @Styles.Render("~/Content/siteCss")
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="~/Content/dark-mode/dark-mode.css" rel="stylesheet" type="text/css" />
    @RenderSection("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        <div class="content-wrapper">
            <div class="content-header">
                <div class="container-fluid">
                    @Html.Partial("_PageHeader")
                </div>
            </div>
            <section class="content">
                <div class="container-fluid text-sm">
                    @RenderBody()
                </div>
            </section>
        </div>
        @Html.Partial("_Footer")
    </div>

    <!-- Bootstrap 3 for AdminLTE 3 compatibility -->
<script src="~/Content/plugins/jquery/jquery.min.js"></script>
<script src="~/Content/plugins/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Content/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="~/Content/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="~/Content/plugins/toastr/toastr.min.js"></script>
<script src="~/Content/plugins/sweetalert2/sweetalert2.all.min.js"></script>
<script src="~/Content/dist/js/adminlte.min.js"></script>
<script src="~/Scripts/site.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="~/Scripts/dark-mode/dark-mode.js"></script>
@RenderSection("Scripts", required: false)

<!-- Bootstrap 3 Modal Transitions - Compatible with IIS -->
<style>
    /* Let Bootstrap handle display, we only enhance transitions */
    .modal.fade .modal-dialog {
        transform: translateY(-80px);
        opacity: 0;
        transition: transform 0.5s ease-out, opacity 0.5s ease-out;
        -webkit-transition: -webkit-transform 0.5s ease-out, opacity 0.5s ease-out;
        -moz-transition: -moz-transform 0.5s ease-out, opacity 0.5s ease-out;
    }
    
    .modal.in .modal-dialog,
    .modal.show .modal-dialog {
        transform: translateY(0);
        opacity: 1;
        -webkit-transform: translateY(0);
        -moz-transform: translateY(0);
    }
    
    /* Modal backdrop transition */
    .modal-backdrop.fade {
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .modal-backdrop.in,
    .modal-backdrop.show {
        opacity: 0.5;
    }
    
    /* Modal content styling */
    .modal .modal-content {
        border: none;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    }
</style>

<!-- Bootstrap 3 Modal Diagnostic -->
<script>
    $(document).ready(function() {
        console.log('=== Bootstrap 3 Modal System ===');
        console.log('jQuery version:', $.fn.jquery);
        console.log('Bootstrap 3 modal available:', typeof $.fn.modal !== 'undefined');
        console.log('AdminLTE 3 loaded:', typeof AdminLTE !== 'undefined');
        
        if (typeof $.fn.modal !== 'undefined') {
            console.log('✅ Bootstrap 3 modal with enhanced transitions ready');
            
            // Log modal events for debugging
            $('.modal').on('show.bs.modal', function() {
                console.log('🎬 Modal showing:', $(this).attr('id'));
            });
            
            $('.modal').on('shown.bs.modal', function() {
                console.log('✅ Modal shown:', $(this).attr('id'));
            });
            
            $('.modal').on('hide.bs.modal', function() {
                console.log('🎬 Modal hiding:', $(this).attr('id'));
            });
            
            $('.modal').on('hidden.bs.modal', function() {
                console.log('✅ Modal hidden:', $(this).attr('id'));
            });
        } else {
            console.log('❌ Bootstrap modal NOT available');
        }
    });
</script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const scrollableSidebar = document.querySelector(".main-sidebar .sidebar");

            // Restore scroll position once
            const savedScroll = sessionStorage.getItem("sidebar-scroll");
            if (savedScroll && scrollableSidebar) {
                scrollableSidebar.scrollTop = parseInt(savedScroll, 10);
                sessionStorage.removeItem("sidebar-scroll"); // Remove after use
            }

            // Save scroll position when clicking a nav link
            const navLinks = document.querySelectorAll(".main-sidebar .nav-link");
            navLinks.forEach(link => {
                link.addEventListener("click", function () {
                    sessionStorage.setItem("sidebar-scroll", scrollableSidebar.scrollTop);
                });
            });
        });
    </script>
</body>
</html>
