@{
    var activeMenu = ViewData["ActiveMenu"]?.ToString() ?? "";
    var activeSubMenu = ViewData["ActiveSubMenu"]?.ToString() ?? "";

    var userGroup = Session["UserGroup"]?.ToString() ?? "";
    bool showMSL = userGroup == "IT" || userGroup == "MSL";
    bool showSQE = userGroup == "IT" || userGroup == "SQE";
    bool showIT = userGroup == "IT";

    var userRole = Session["UserRole"]?.ToString() ?? "";
    bool allowManagementModule = userRole == "Admin";
}
<aside class="main-sidebar sidebar-dark-white elevation-4">
    <!-- Brand Logo -->
    <a href="#" class="brand-link d-flex align-items-center">
        <img src="@Url.Content("~/Content/dist/img/wdpngnew.png")" width="48" height="48" class="mr-2" title="WD Logo" style="object-fit: contain;" />
        <div class="d-flex flex-column justify-content-center" style="line-height: 1;">
            <span class="brand-text font-weight-bold" style="font-size: 1.1rem;">MSL</span>
            <span class="brand-text font-weight-light" style="font-size: 0.9rem;">Management System</span>
        </div>
    </a>

