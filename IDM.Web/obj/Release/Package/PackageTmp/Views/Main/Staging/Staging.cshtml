@{
    ViewBag.Title = "Staging Data";

    var userRole = Session["UserRole"]?.ToString() ?? "";
    bool allowDecisionButtons = userRole == "Admin";

} 
<div class="card mb-3">
    <div class="card-header bg-light">
        <h6 class="mb-0">
            @*<i class="fas fa-calendar-alt me-2"></i>*@ 
            <label id="AnalysisName"></label> <label > Details</label>
        </h6>
    </div>
    <div class="card-body">
        <div class="row" id="headerInfoContainer">
            
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body px-4 py-3">
        <div class="table-responsive">
            <table id="stagingTable" class="table table-hover align-middle w-100">
                <thead class="text-dark">
                </thead>
                <tbody></tbody>
            </table>
            <table id="stagingTablecontainer" class="table table-hover align-middle w-100" style="display:none!important">
                <thead class="text-dark">
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div class="card-footer border-top bg-light px-4 py-3 d-flex justify-content-end gap-5">
        @if (allowDecisionButtons)
        {
            <button type="button" id="reject-btn" class="btn btn-danger" style="width: 120px; height: 40px; margin-right: 5px;">
                <i class="fas fa-times"></i>&nbsp;Reject
            </button>
            <button type="button" id="approve-btn" class="btn btn-success" style="width: 120px; height: 40px;">
                <i class="fas fa-check"></i>&nbsp;Approve
            </button>
        }
        else
        {
            <button type="button" class="btn btn-danger disabled" style="width: 120px; height: 40px; margin-right: 5px;" disabled >
                <i class="fas fa-times"></i>&nbsp;Reject
            </button>
            <button type="button" class="btn btn-success disabled" style="width: 120px; height: 40px;" disabled>
                <i class="fas fa-check"></i>&nbsp;Approve
            </button>
        }

    </div>
</div>

@section Scripts {
    <script>
       const AppUrls = {
           setApproval: '@Url.Action("SetApproval", "Staging", new { area = "Main" })',
           getByAnalysisAsync: '@Url.Action("GetByAnalysisAsync", "Staging", new { area = "Main" })',
           getByJobAndAnalysisAsync: '@Url.Action("GetByJobAndAnalysisAsync", "Staging", new { area = "Main" })'
        };

    </script>

    <script src="~/Scripts/Main/staging.js"></script>
}