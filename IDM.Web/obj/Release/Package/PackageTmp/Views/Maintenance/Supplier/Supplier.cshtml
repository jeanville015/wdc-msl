@{
    ViewBag.Title = "Supplier";
}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom px-4 py-3">
        <button class="btn btn-primary btn-sm float-right" id="addSupplier">
            <i class="fas fa-plus"></i> Add Supplier
        </button>
    </div>
    <div class="card-body px-4 py-3">
        <div class="table-responsive">
            <table id="supplierTable" class="table table-hover align-middle w-100">
                <thead class="text-dark">
                    <tr>
                        <th>Supplier</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="supplierModal" aria-modal="true" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-white border-bottom px-4 py-3">
                <h5 class="modal-title text-dark font-weight-semibold">Supplier Details</h5>
                <button type="button" id="close-supplier" class="close text-dark" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Supplier <span class="text-danger">*</span></label>
                        <input type="text" id="txtSupplier" class="form-control" placeholder="Enter Supplier">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top bg-light px-4 py-3 d-flex justify-content-end">
                <button type="button" id="cancel-supplier" class="btn btn-outline-secondary px-4">
                    Cancel
                </button>
                <button type="button" id="save-supplier" class="btn btn-primary px-4">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
       const AppUrls = {
            getSupplier: '@Url.Action("GetSupplier", "Supplier", new { area = "Maintenance" })',
            addSupplier: '@Url.Action("Create", "Supplier", new { area = "Maintenance" })',
            editSupplier: '@Url.Action("Edit", "Supplier", new { area = "Maintenance" })',
            deleteSupplier: '@Url.Action("Delete", "Supplier", new { area = "Maintenance" })'
        };

    </script>

    <script src="~/Scripts/Maintenance/supplier.js"></script>
}