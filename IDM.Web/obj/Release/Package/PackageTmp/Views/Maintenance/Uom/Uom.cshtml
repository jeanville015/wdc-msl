@{
    ViewBag.Title = "Uom";
}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom px-4 py-3">
        <button class="btn btn-primary btn-sm float-right" id="addUom">
            <i class="fas fa-plus"></i> Add Uom
        </button>
    </div>
    <div class="card-body px-4 py-3">
        <div class="table-responsive">
            <table id="uomTable" class="table table-hover align-middle w-100">
                <thead class="text-dark">
                    <tr>
                        <th>Uom</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="uomModal" aria-modal="true" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-white border-bottom px-4 py-3">
                <h5 class="modal-title text-dark font-weight-semibold">Uom Details</h5>
                <button type="button" id="close-uom" class="close text-dark" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Uom <span class="text-danger">*</span></label>
                        <input type="text" id="txtUom" class="form-control" placeholder="Enter Uom">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top bg-light px-4 py-3 d-flex justify-content-end">
                <button type="button" id="cancel-uom" class="btn btn-outline-secondary px-4">
                    Cancel
                </button>
                <button type="button" id="save-uom" class="btn btn-primary px-4">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
       const AppUrls = {
            getUom: '@Url.Action("GetUom", "Uom", new { area = "Maintenance" })',
            addUom: '@Url.Action("Create", "Uom", new { area = "Maintenance" })',
            editUom: '@Url.Action("Edit", "Uom", new { area = "Maintenance" })',
            deleteUom: '@Url.Action("Delete", "Uom", new { area = "Maintenance" })'
        };

    </script>

    <script src="~/Scripts/Maintenance/uom.js"></script>
}