@{
    ViewBag.Title = "Parameter";
}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom px-4 py-3">
        <button class="btn btn-primary btn-sm float-right" id="addParameter">
            <i class="fas fa-plus"></i> Add Parameter
        </button>
    </div>
    <div class="card-body px-4 py-3">
        <div class="table-responsive">
            <table id="parameterTable" class="table table-hover align-middle w-100">
                <thead class="text-dark">
                    <tr>
                        <th>Parameter</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="parameterModal" aria-modal="true" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-white border-bottom px-4 py-3">
                <h5 class="modal-title text-dark font-weight-semibold">Parameter Details</h5>
                <button type="button" id="close-parameter" class="close text-dark" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Parameter <span class="text-danger">*</span></label>
                        <input type="text" id="txtParameter" class="form-control" placeholder="Enter Parameter">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top bg-light px-4 py-3 d-flex justify-content-end">
                <button type="button" id="cancel-parameter" class="btn btn-outline-secondary px-4">
                    Cancel
                </button>
                <button type="button" id="save-parameter" class="btn btn-primary px-4">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
       const AppUrls = {
           getParameter: '@Url.Action("GetParameter", "Parameter", new { area = "Maintenance" })',
           addParameter: '@Url.Action("Create", "Parameter", new { area = "Maintenance" })',
           editParameter: '@Url.Action("Edit", "Parameter", new { area = "Maintenance" })',
           deleteParameter: '@Url.Action("Delete", "Parameter", new { area = "Maintenance" })'
        };

    </script>

    <script src="~/Scripts/Maintenance/parameter.js"></script>
}