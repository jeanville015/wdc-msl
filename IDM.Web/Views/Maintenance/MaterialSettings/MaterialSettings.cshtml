@{
    ViewBag.Title = "Material Settings";
}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom px-4 py-3">
        <button class="btn btn-primary btn-sm float-right" id="addMaterialSettings">
            <i class="fas fa-plus"></i> Add Material Settings
        </button>
    </div>
    <div class="card-body px-4 py-3">
        <div class="table-responsive">
            <table id="materialSettingsTable" class="table table-hover align-middle w-100">
                <thead class="text-dark">
                    <tr>
                        <th>Tool Type</th>
                        <th>Material Number</th>
                        <th>Material Name</th>
                        <th>Settings Name</th>
                        <th>Settings Value</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="materialSettingsModal" aria-modal="true" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-white border-bottom px-4 py-3">
                <h5 class="modal-title text-dark font-weight-semibold">Material Settings Details</h5>
                <button type="button" id="close-materialSettings" class="close text-dark" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Tool Type <span class="text-danger">*</span></label>
                        <select id="ddlToolType" class="form-control">
                        </select>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label>Material Number <span class="text-danger">*</span></label>
                        <select id="ddlMaterialNumber" class="form-control">
                        </select>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label>Settings Name <span class="text-danger">*</span></label>
                        <input type="text" id="txtSettingsName" class="form-control" placeholder="Enter Settings Name">
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label>Settings Value <span class="text-danger">*</span></label>
                        <input type="text" id="txtSettingsValue" class="form-control" placeholder="Enter Settings Value">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top bg-light px-4 py-3 d-flex justify-content-end">
                <button type="button" id="cancel-materialSettings" class="btn btn-outline-secondary px-4">
                    Cancel
                </button>
                <button type="button" id="save-materialSettings" class="btn btn-primary px-4">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
       const AppUrls = {
           getMaterialSettings: '@Url.Action("GetMaterialSettings", "MaterialSettings", new { area = "Maintenance" })',
           addMaterialSettings: '@Url.Action("Create", "MaterialSettings", new { area = "Maintenance" })',
           editMaterialSettings: '@Url.Action("Edit", "MaterialSettings", new { area = "Maintenance" })',
           deleteMaterialSettings: '@Url.Action("Delete", "MaterialSettings", new { area = "Maintenance" })',

           getMaterial: '@Url.Action("GetMaterial", "Material", new { area = "Maintenance" })',
           getToolType: '@Url.Action("GetToolType", "ToolType", new { area = "Maintenance" })'
        };

    </script>

    <script src="~/Scripts/Maintenance/materialSettings.js"></script>
}