@using IDM.DTO.Main
@model IDM.DTO.Main.PagedResultDTO<IDM.DTO.Main.PendingDataDTO>

@if (Model != null && Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle w-100">
            <thead class="thead-light">
                <tr>
                    <th>Delivery Date</th>
                    <th>Received Date</th>
                    <th>Lot Number</th>
                    <th>Material No</th>
                    <th>Material Name</th>
                    <th>Job Number</th>
                    <th>Tool Id</th>
                    <th>Actions</th>
                </tr>
            </thead> 
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Delivery_Date</td>
                        <td>@item.Received_Date</td>
                        <td>@item.LotNumber</td>
                        <td>@item.Material_No</td>
                        <td>@item.Material_Name</td>
                        <td>@item.Job_Number</td>
                        <td>@item.ToolId</td>
                        <td>
                            <a href="#" class="share-btn"
                               data-delivery="@item.Delivery_Date"
                               data-received="@item.Received_Date"
                               data-lot="@item.LotNumber"
                               data-material="@item.Material_No"
                               data-job="@item.Job_Number"
                               data-tool="@item.ToolId">
                                <i class="fa-solid fa-share"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    <div class="d-flex justify-content-between align-items-center mt-3">

        <!-- Record Count Label -->
        <small class="text-muted">
            Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount))
            of @Model.TotalCount records
        </small>

        <!-- Page Number Buttons -->
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">

                @{
                    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                    int start = Math.Max(1, Model.CurrentPage - 2);
                    int end = Math.Min(Model.TotalPages, start + 4);
                }

                <!-- Previous -->
                <li class="page-item @prevDisabled">
                    <a class="page-link" href="javascript:loadPendingData(@(Model.CurrentPage - 1))">
                        &laquo;
                    </a>
                </li>

                <!-- First + ellipsis -->
                @if (start > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:loadPendingData(1)">1</a>
                    </li>
                    if (start > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                <!-- Sliding window -->
                @for (int i = start; i <= end; i++)
                {
                    var activeClass = (i == Model.CurrentPage) ? "active" : "";
                    <li class="page-item @activeClass">
                        <a class="page-link" href="javascript:loadPendingData(@i)">@i</a>
                    </li>
                }

                <!-- Last + ellipsis -->
                @if (end < Model.TotalPages)
                {
                    if (end < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="javascript:loadPendingData(@Model.TotalPages)">
                            @Model.TotalPages
                        </a>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @nextDisabled">
                    <a class="page-link" href="javascript:loadPendingData(@(Model.CurrentPage + 1))">
                        &raquo;
                    </a>
                </li>

            </ul>
        </nav>

        <!-- Rows Per Page Selector -->
        <div class="d-flex align-items-center gap-2">
            <label class="mb-0 text-muted small">Rows per page:</label>
            <select class="form-control form-control-sm w-auto"
                    onchange="loadPendingData(1, this.value)">
                @foreach (var size in new[] { 2, 5, 10, 25, 50, 100 })
                {
                    var selected = (Model.PageSize == size) ? "selected" : "";
                    <option value="@size" @selected>@size</option>
                }
            </select>
        </div>

    </div>
}
else
{
    <div class="alert alert-info">No pending records found.</div>
}

<div class="modal fade" id="shareModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Details</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3 p-2 bg-light border rounded small text-muted"
                     id="shareModalParams"></div>
            </div>
            <div id="GridWControls">
                <div class="text-center text-muted py-4">Loading...</div>
            </div>
        </div>
    </div>
</div>