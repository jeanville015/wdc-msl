@using IDM.DTO.Main
@model IDM.DTO.Main.PagedResultDTO<IDM.DTO.Main.PendingDataDTO>

@{
    var userRole = Session["UserRole"]?.ToString() ?? "";
    bool allowDecisionButtons = userRole == "Admin";
}
 
<div class="modal-body"> 
    <div id="shareModalContent">
        @if (Model != null && Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle w-100">
                    <thead class="thead-light">
                        <tr>
                            <th>Delivery Date</th>
                            <th>Received Date</th>
                            <th>Lot Number</th>
                            <th>Material No</th>
                            <th>Material Name</th>
                            <th>Job Number</th>
                            <th>Tool Id</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Delivery_Date</td>
                                <td>@item.Received_Date</td>
                                <td>@item.LotNumber</td>
                                <td>@item.Material_No</td>
                                <td>@item.Material_Name</td>
                                <td>@item.Job_Number</td>
                                <td>@item.ToolId</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls — same pattern as main view -->
            <div class="d-flex justify-content-between align-items-center mt-3">

                <small class="text-muted">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)
                    – @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)
                    of @Model.TotalCount records
                </small>

                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">

                        @{
                            var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                            var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                            int start = Math.Max(1, Model.CurrentPage - 2);
                            int end = Math.Min(Model.TotalPages, start + 4);
                        }

                        <li class="page-item @prevDisabled">
                            <a class="page-link"
                               href="javascript:loadShareDetails(@(Model.CurrentPage - 1))">
                                &laquo;
                            </a>
                        </li>

                        @if (start > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:loadShareDetails(1)">1</a>
                            </li>
                            if (start > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">…</span>
                                </li>
                            }
                        }

                        @for (int i = start; i <= end; i++)
                        {
                            var activeClass = (i == Model.CurrentPage) ? "active" : "";
                            <li class="page-item @activeClass">
                                <a class="page-link"
                                   href="javascript:loadShareDetails(@i)">@i</a>
                            </li>
                        }

                        @if (end < Model.TotalPages)
                        {
                            if (end < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">…</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link"
                                   href="javascript:loadShareDetails(@Model.TotalPages)">
                                    @Model.TotalPages
                                </a>
                            </li>
                        }

                        <li class="page-item @nextDisabled">
                            <a class="page-link"
                               href="javascript:loadShareDetails(@(Model.CurrentPage + 1))">
                                &raquo;
                            </a>
                        </li>

                    </ul>
                </nav>

                <div class="d-flex align-items-center">
                    <label class="mb-0 text-muted small mr-2">Rows per page:</label>
                    <select class="form-control form-control-sm w-auto"
                            onchange="loadShareDetails(1, this.value)">
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            var selected = (Model.PageSize == size) ? "selected" : "";
                            <option value="@size" @selected>@size</option>
                        }
                    </select>
                </div>

            </div>

            <div class="px-4 py-3 d-flex justify-content-end gap-5"> <!--action buttons here--> </div>
        }
        else
        {
            <div class="alert alert-info">No records found.</div>
        }

    </div>
</div>
<div class="modal-footer">
    @if (allowDecisionButtons)
    {
        <button type="button" id="reject-btn" class="btn btn-danger" style="width: 120px; height: 40px; margin-right: 5px;">
            <i class="fas fa-times"></i>&nbsp;Reject
        </button>
        <button type="button" id="approve-btn" class="btn btn-success" style="width: 120px; height: 40px;">
            <i class="fas fa-check"></i>&nbsp;Approve
        </button>
    }
    else
    {
        <button type="button" class="btn btn-danger disabled" style="width: 120px; height: 40px; margin-right: 5px;" disabled>
            <i class="fas fa-times"></i>&nbsp;Reject
        </button>
        <button type="button" class="btn btn-success disabled" style="width: 120px; height: 40px;" disabled>
            <i class="fas fa-check"></i>&nbsp;Approve
        </button>
    }
    <button type="button" class="btn btn-secondary"
            data-dismiss="modal">
        Close
    </button>
</div>  